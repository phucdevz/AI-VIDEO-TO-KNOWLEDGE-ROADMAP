# FastAPI backend
VITE_API_URL=http://127.0.0.1:8000

# Supabase (auth + realtime + preferences). If unset, app skips auth gate and uses mock library.
VITE_SUPABASE_URL=
# Use the anon "public" JWT from Dashboard → API (string starting with eyJ…). Publishable keys (sb_publishable_…)
# often break signInWithPassword (400 on /auth/v1/token).
VITE_SUPABASE_ANON_KEY=

# Optional: canonical origin for SEO
# VITE_SITE_URL=http://localhost:5173
